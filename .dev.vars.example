NEXT_PUBLIC_APP_URL="https://aksharevents.pages.dev"
NEXT_PUBLIC_APP_NAME="AksharEvents"
FRONTEND_ONLY="false"

STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
