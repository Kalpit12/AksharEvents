# Database
# Local Postgres:
# DATABASE_URL="postgresql://user:password@localhost:5432/akshar_events?schema=public"
#
# Neon (recommended):
# DATABASE_URL  = pooled connection string (hostname contains "-pooler")
# DIRECT_URL    = direct connection string (for prisma migrate / db push)
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/akshar_events?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/akshar_events?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Local dev only — on Vercel set to your production URL (e.g. https://akshar-events-delta.vercel.app)
AUTH_URL="http://localhost:5001"

# Stripe
STRIPE_SECRET_KEY="sk_test_xxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Email (Postmark)
POSTMARK_API_KEY="your-postmark-server-token"
POSTMARK_SENDER_EMAIL="info@aksharjobs.com"
POSTMARK_SENDER_NAME="AksharEvents"
POSTMARK_MESSAGE_STREAM="outbound"

# App — must match your deployed domain in production (used for metadata, emails, Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:5001"
NEXT_PUBLIC_APP_NAME="AksharEvents"

# Set to "true" to run the UI with mock data (no database required)
FRONTEND_ONLY="true"

# Neon dev tip: append to DATABASE_URL to reduce idle pool noise:
# &connection_limit=5&connect_timeout=15

# Flight booking (Event Master → travel agent)
FLIGHT_BOOKING_AGENT_EMAIL="samantha.mutinda@maxproinfotech.com"
FLIGHT_BOOKING_CC_EMAIL="info@aksharevents.com"
EVENT_MASTER_NOTIFICATION_EMAIL="info@aksharevents.com"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
